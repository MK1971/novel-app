APP_NAME=WhatsMyBookName
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Must match the origin you open in the browser (scheme + host + port). For
# `php artisan serve`, include the port, e.g. http://127.0.0.1:8000 — Google OAuth
# redirect_uri must match Console exactly (redirect_uri_mismatch if wrong host/port).
APP_URL=http://localhost

# Legal identity (used on Terms/Privacy pages)
# LEGAL_ENTITY_NAME=WhatsMyBookName Ltd.
# LEGAL_ENTITY_ADDRESS=123 Example St, City, Country
# LEGAL_CONTACT_EMAIL=legal@whatsmybookname.com
# LEGAL_JURISDICTION=State of Israel
# LEGAL_DISPUTE_NOTICE_DAYS=30

# Admin login (see AdminOnlySeeder). Also used as fallback for paid-suggestion admin email
# if "Admin notification email" is empty in /admin/settings.
# ADMIN_EMAIL=admin@example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Usually null for local dev; set only if you need a specific cookie domain.
SESSION_DOMAIN=null
# Local HTTP (e.g. php artisan serve): false. Production behind HTTPS: set true.
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: use "log" to write messages to storage/logs/laravel.log (default below).
# For real SMTP (Cloudways/production or Mailpit/Mailhog locally), set MAIL_MAILER=smtp and fill host/port/user/pass.
# Test from the project root: php artisan mail:test your@email.com
MAIL_MAILER=log
MAIL_SCHEME=null
# Optional backward compatibility alias used by some hosts (config/mail.php falls back to it):
# MAIL_ENCRYPTION=tls
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# Cloudways SMTP quick example:
# MAIL_MAILER=smtp
# MAIL_SCHEME=tls
# MAIL_HOST=smtp.cloudwaysapps.com
# MAIL_PORT=587
# MAIL_USERNAME=your_cloudways_smtp_username
# MAIL_PASSWORD=your_cloudways_smtp_password
# MAIL_FROM_ADDRESS=no-reply@whatsmybookname.com
# Local Mailpit (same machine as `php artisan serve`): use 127.0.0.1 — not the hostname "mailpit"
# unless PHP runs inside Docker and that service name resolves.
# MAIL_MAILER=smtp
# MAIL_HOST=127.0.0.1
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OAuth — Google / Apple sign-in (optional; Google buttons need client id + secret below)
# Apple UI and /auth/apple/* stay off until APPLE_SIGN_IN_ENABLED=true (see config/services.php).
# APPLE_SIGN_IN_ENABLED=false
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
# APPLE_CLIENT_ID=
# APPLE_REDIRECT_URI="${APP_URL}/auth/apple/callback"
# Prefer key-based client secret (see Apple Developer → Keys → Sign in with Apple):
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=/absolute/path/to/AuthKey_XXXXX.p8
# Or set a JWT client secret (rotates ~every 6 months) instead of the three lines above:
# APPLE_CLIENT_SECRET=

# Landing stats strip — prize line (campaign goal, not from DB)
# LANDING_PRIZE_POOL_DISPLAY="$50k"
# LANDING_SOFT_STATS_WHEN_EMPTY=true
# SEO_DEFAULT_DESCRIPTION="…"
# SEO_OG_IMAGE_URL=

# TBWNN pilot chapter (first manuscript upload): close paid editing after N accepted suggestions (story + inline), not by calendar alone. Default 50.
# TBWNN_PILOT_CLOSE_AFTER_ACCEPTED=50

# Peter Trull pilot voting pair: close voting after N total votes (A + B), not by calendar alone. Default 50.
# PETER_TRULL_PILOT_CLOSE_AFTER_VOTES=50

# PayPal (get sandbox/live credentials from https://developer.paypal.com)
PAYPAL_MODE=sandbox
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
# For production:
# PAYPAL_LIVE_CLIENT_ID=
# PAYPAL_LIVE_CLIENT_SECRET=
# Webhook auth (recommended: set PAYPAL_WEBHOOK_ID for signature verification)
# PAYPAL_WEBHOOK_ID=
# Fallback shared token mode (local/testing or temporary fallback)
# PAYPAL_WEBHOOK_TOKEN=

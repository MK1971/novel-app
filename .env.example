APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Admin login (see AdminOnlySeeder). Also used as fallback for paid-suggestion admin email
# if "Admin notification email" is empty in /admin/settings.
# ADMIN_EMAIL=admin@example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Omit or false for local HTTP (e.g. artisan serve). Set true in production behind HTTPS.
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: use "log" to write messages to storage/logs/laravel.log (default below).
# For real SMTP (production or Mailpit/Mailhog locally), set MAIL_MAILER=smtp and fill host/port/user/pass.
# Test from the project root: php artisan mail:test your@email.com
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# Local Mailpit (same machine as `php artisan serve`): use 127.0.0.1 — not the hostname "mailpit"
# unless PHP runs inside Docker and that service name resolves.
# MAIL_MAILER=smtp
# MAIL_HOST=127.0.0.1
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Landing stats strip — prize line (campaign goal, not from DB)
# LANDING_PRIZE_POOL_DISPLAY="$50k"
# LANDING_SOFT_STATS_WHEN_EMPTY=true
# SEO_DEFAULT_DESCRIPTION="…"
# SEO_OG_IMAGE_URL=

# PayPal (get sandbox credentials from https://developer.paypal.com)
PAYPAL_MODE=sandbox
PAYPAL_SANDBOX_CLIENT_ID=AemOuhFIH11bAwi-O562Z7ysO3Nx8BnqzvQeL9wrvEkw8jwgdFNkCBbkCrSKwrc5D6m27QndDxz8fEiO
PAYPAL_SANDBOX_CLIENT_SECRET=ELWPZyxxDxo7uGJ5b_1FX41gBYgvmu1LUkuzv2FhcXwvBtHSFB-08jrLhtbbnqdxRORQc0kAZJ8L5zHb
# For production:
